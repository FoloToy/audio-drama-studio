# 复制本文件为 .env 并填入真实 Key。各项详细说明见 .env 内注释。

# LLM（二选一，优先 DeepSeek；全空则 demo 模式）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_API_KEY=
CLAUDE_API_BASE=
CLAUDE_MODEL=claude-sonnet-4-20250514

# TTS 配音（豆包 seed-tts-2.0）
DOUBAO_API_KEY=

# BGM（MiniMax music-2.6）
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# 音效（ElevenLabs）
ELEVENLABS_API_KEY=

# 备用 / 运行目录 / 端口
SUNO_API_URL=http://localhost:3000
OUTPUT_DIR=./output
SFX_DIR=./assets/sfx
BGM_DIR=./assets/bgm
PORT=5001
